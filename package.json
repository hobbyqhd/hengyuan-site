{
  "name": "hengyuan-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prepare:products": "node tools/prepare-products-data.mjs",
    "sync:hy-images": "node tools/sync-hy-images.mjs",
    "predev": "node tools/prepare-products-data.mjs && node tools/stitch.mjs",
    "dev": "vite --config vite.site.config.mjs",
    "prebuild": "node tools/prepare-products-data.mjs && node tools/stitch.mjs",
    "build": "vite build --config vite.site.config.mjs",
    "preview": "vite preview --config vite.site.config.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "vite": "^6.3.5",
    "wrangler": "^4.22.0"
  }
}
